# Managed by Ansible (deploy_services) — module-ttt service.
services:
  module-ttt:
    image: {{ module_ttt_image }}:{{ module_ttt_image_tag }}
    container_name: module-ttt
    restart: unless-stopped
    env_file:
      - path: {{ deploy_base_dir }}/config/.env
        required: false
    networks:
      - {{ docker_network_name }}
    volumes:
      - {{ deploy_base_dir }}/data:/app/data
      - tdb-spool:/var/tmp/tdb-spool
    labels:
      - traefik.enable=true
      - traefik.http.routers.module-ttt.rule=Host(`${TTT_BACKEND_HOST}`)
      - traefik.http.routers.module-ttt.entrypoints=websecure
      - traefik.http.routers.module-ttt.tls.certresolver=le
      - traefik.http.services.module-ttt.loadbalancer.server.port=8090

networks:
  {{ docker_network_name }}:
    name: {{ docker_network_name }}
    external: true

volumes:
  tdb-spool:
